# Copy to keystore.properties (gitignored) and fill in to enable signed release builds.
# Paths are resolved relative to the repository root. One keystore per flavor.
#
# bloodpressure.storeFile=keystores/bloodpressure-release.jks
# bloodpressure.storePassword=changeit
# bloodpressure.keyAlias=bloodpressure
# bloodpressure.keyPassword=changeit
#
# glucose.storeFile=keystores/glucose-release.jks
# glucose.storePassword=changeit
# glucose.keyAlias=glucose
# glucose.keyPassword=changeit
#
# mood.storeFile=keystores/mood-release.jks
# mood.storePassword=changeit
# mood.keyAlias=mood
# mood.keyPassword=changeit
